{
	"version": 2,
	"builds": [
		{
			"src": "server.js",
			"use": "@vercel/node"
		}
	],
	"routes": [
		{
			"src": "/docs/(.*)",
			"dest": "/server.js"
		},
		{
			"src": "/(.*)",
			"dest": "/server.js"
		}
	],
	"rewrites": [
		{
			"source": "/docs/(.*)",
			"destination": "/server.js"
		}
	],
	"crons": [
		{
			"path": "/api/v1/clusters/run",
			"schedule": "0 2 * * *"
		}
	]
}
